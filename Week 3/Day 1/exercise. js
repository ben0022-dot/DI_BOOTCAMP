
 const    numbers = [5, 0, 9, 1, 7, 4, 2, 6, 3, 8];

// Using .toString()
// This always returns a comma-separated string.
const string1 = numbers.toString(); 
console.log("toString:", string1); // "5,0,9,1,7,4,2,6,3,8"

// Using .join()
// This gives you control over the "glue" between elements.
console.log("join with '+':", numbers.join("+")); // "5+0+9+1+7+4+2+6+3+8"
console.log("join with space:", numbers.join(" ")); // "5 0 9 1 7 4 2 6 3 8"
console.log("join with nothing:", numbers.join("")); // "5091742638"

const number = [5, 0, 9, 1, 7, 4, 2, 6, 3, 8];

// Outer loop: Determines how many times we pass through the array
for (let i = 0; i < numbers.length; i++) {
    
    // Inner loop: Compares adjacent elements
    // We use numbers.length - 1 - i because after each outer pass, 
    // the smallest number has already "bubbled" to the end.
    for (let j = 0; j < numbers.length - 1 - i; j++) {
        
        // Compare current element with the next one
        // For descending order, if the current (j) is LESS than the next (j+1), swap them.
        if (numbers[j] < numbers[j + 1]) {
            
            console.log(`Swapping ${numbers[j]} and ${numbers[j+1]}`);
            
            // 1. Store the value of numbers[j] in a temporary variable
            let temp = numbers[j];
            
            // 2. Move the larger value into the current position
            numbers[j] = numbers[j + 1];
            
            // 3. Put the temporary value into the next position
            numbers[j + 1] = temp;
        }
    }
    // Check the array status after each full pass of the inner loop
    console.log(`Pass ${i + 1} complete. Current array:`, numbers);
}

console.log("Final Sorted Array:", numbers);
